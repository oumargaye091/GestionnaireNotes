<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:id="@+id/layoutRecherche"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_alignParentTop="true">

        <EditText
            android:id="@+id/editRecherche"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Rechercher"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_recherche"
            android:inputType="text"
            android:imeOptions="actionSearch"/>

        <Button
            android:id="@+id/btnFavoris"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="Favoris"
            android:textColor="@color/noir"
            android:background="@drawable/bg_btn_favoris"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

    </LinearLayout>

    <!-- Barre Compteur + Tri + Mode sombre -->
    <LinearLayout
        android:id="@+id/layoutBarre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutRecherche"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textCompteur"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 note"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnTri"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Tri: Date"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"/>

        <Button
            android:id="@+id/btnTheme"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:text="🌙"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/textAucuneNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aucune note"
        android:textSize="16sp"
        android:textColor="@color/gris"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNotes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutBarre"
        android:layout_above="@+id/fabAjouter"
        android:paddingBottom="16dp"/>

    <!-- Palette de couleurs (création) -->
    <LinearLayout
        android:id="@+id/layoutPalette"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="31dp"
        android:layout_marginBottom="80dp"
        android:visibility="gone">

        <View android:id="@+id/btnVert"   android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="6dp" android:background="@drawable/bg_couleur_vert"/>
        <View android:id="@+id/btnRouge"  android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="6dp" android:background="@drawable/bg_couleur_rouge"/>
        <View android:id="@+id/btnBleu"   android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="6dp" android:background="@drawable/bg_couleur_bleu"/>
        <View android:id="@+id/btnJaune"  android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="6dp" android:background="@drawable/bg_couleur_jaune"/>
        <View android:id="@+id/btnOrange" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="6dp" android:background="@drawable/bg_couleur_orange"/>
        <View android:id="@+id/btnGris"   android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="6dp" android:background="@drawable/bg_couleur_gris"/>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAjouter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/noir"
        app:tint="@color/blanc"/>

</RelativeLayout>
